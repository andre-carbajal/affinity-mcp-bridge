{
  "name": "affinity-mcp-bridge",
  "version": "0.2.0",
  "description": "A standalone MCP stdio bridge for Affinity by Canva's local MCP SSE server.",
  "type": "module",
  "bin": {
    "affinity-mcp-bridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "smoke": "npm run build && node scripts/smoke-list-tools.mjs",
    "check": "tsc --noEmit && node --check scripts/smoke-list-tools.mjs",
    "prepublishOnly": "npm run build && npm run check"
  },
  "keywords": [
    "affinity",
    "canva",
    "mcp",
    "model-context-protocol",
    "claude",
    "codex"
  ],
  "author": "Andre Carbajal",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andre-carbajal/affinity-mcp-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/andre-carbajal/affinity-mcp-bridge/issues"
  },
  "homepage": "https://github.com/andre-carbajal/affinity-mcp-bridge#readme",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
